# Server Configuration
PORT=5000

# Database Configuration
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/ExpenseTracker?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5174

# Email (Nodemailer) — required for budget alert emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM="FinTrack Alerts <your-email@gmail.com>"

# Budget alert thresholds (comma-separated percentages)
BUDGET_ALERT_THRESHOLDS=80,90,100
